# Auto detect text files and normalize line endings to LF
* text=auto

# JSON files
*.json text eol=lf
package.json text eol=lf
package-lock.json text eol=lf

# JavaScript/Node files
*.js text eol=lf
*.jsx text eol=lf
*.mjs text eol=lf

# YAML files
*.yml text eol=lf
*.yaml text eol=lf

# Markdown
*.md text eol=lf

# Shell scripts
*.sh text eol=lf
*.bash text eol=lf

# Windows batch files
*.bat text eol=crlf
*.cmd text eol=crlf
*.ps1 text eol=crlf
